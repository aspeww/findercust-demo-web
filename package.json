{
  "name": "findercust-demo-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "vercel-build": "DATABASE_URL=file:./prisma/demo.db prisma generate && DATABASE_URL=file:./prisma/demo.db prisma migrate deploy && DATABASE_URL=file:./prisma/demo.db npm run db:seed && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "db:migrate:layered-categories": "tsx prisma/migrate-layered-categories.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
