# --- App ---
NODE_ENV=production
PORT=3000

# --- Database (SQLite; build sırasında seed ile oluşturulur) ---
DATABASE_URL="file:./demo.db"

# --- Auth.js ---
# Generate: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST=true

# --- Demo mode (Vercel/canlı demo için true yapın) ---
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true
DEMO_SEED=true
DEMO_USER_EMAIL=demo@findercust.com
DEMO_USER_PASSWORD=Demo123!

# --- Google Maps Places API ---
GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- Gemini (AI website generation; template fallback if empty) ---
GEMINI_API_KEY=""
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FORCE_TEMPLATE=true
